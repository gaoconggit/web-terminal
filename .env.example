# Listening port (default: 7681)
# WEB_TERMINAL_PORT=7681

# Bind address (default: 127.0.0.1)
# WEB_TERMINAL_BIND=127.0.0.1

# Auth token (default: random on each start)
# WEB_TERMINAL_TOKEN=mycc

# Working directory (default: current directory)
# WEB_TERMINAL_CWD=.

# Tab configuration (JSON array)
# WEB_TERMINAL_TABS=[{"id":"claude","label":"CC","cmd":"claude","args":["--continue","--dangerously-skip-permissions"]}]
